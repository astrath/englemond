{
	"name": "twentytwentyfive",
	"version": "1.4.0",
	"description": "Default WP Theme",
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"WordPress",
		"Theme"
	],
	"bugs": {
		"url": "https://core.trac.wordpress.org/"
	},
	"homepage": "https://wordpress.org/themes/twentytwentyfive/",
	"engines": {
		"node": ">=20.10.0",
		"npm": ">=10.2.3"
	},
	"devDependencies": {
		"@babel/core": "^7.23.0",
		"@babel/preset-env": "^7.23.0",
		"@wordpress/browserslist-config": "^6.34.0",
		"autoprefixer": "^10.4.16",
		"babel-loader": "^9.1.3",
		"css-loader": "^6.8.1",
		"cssnano": "^7.1.2",
		"mini-css-extract-plugin": "^2.7.6",
		"postcss": "^8.5.6",
		"postcss-cli": "^11.0.1",
		"postcss-loader": "^7.3.3",
		"sass": "^1.97.3",
		"sass-loader": "^16.0.7",
		"webpack": "^5.89.0",
		"webpack-cli": "^5.1.4"
	},
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"scripts": {
		"build": "NODE_ENV=production webpack --mode production",
		"dev": "webpack --mode development --watch",
		"build:css": "postcss style.css --use cssnano -o style.min.css --no-map",
		"watch:css": "postcss style.css --use cssnano -o style.min.css --no-map --watch"
	}
}
