{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "englemond/selection",
	"title": "Englemond Selection",
	"category": "englemond",
	"icon": "products",
	"description": "A selection block for Englemond products",
	"keywords": ["products", "selection", "englemond"],
	"textdomain": "englemond-products",
	"editorScript": "file:./build/editor.js",
	"editorStyle": ["dashicons"],
	"viewScript": "file:./build/view.js",
	"style": ["file:./build/view.css"],
	"render": "file:./render.php",
	"attributes": {
		"source": {
			"type": "object",
			"default": {
				"type": "",
				"data": [],
				"term": null,
				"maxResults": null
			}
		},
		"title":{
			"type": "string",
			"default": ""
		},
		"view": {
			"type": "object",
			"default": {
				"type": "carousel",
				"columnsCount": 3
			}
		},
		"backgroundImage": {
			"type": "object",
			"default": null
		}
	},
	"styles": [
		{
			"name": "default",
			"label": "Default",
			"isDefault": true
		}
	],
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"className": true,
		"__experimentalSelector": ".wp-block-englemond-selection"
	}
}
