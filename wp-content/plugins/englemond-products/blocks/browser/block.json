{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "englemond/browser",
	"title": "Englemond Product Browser",
	"category": "englemond",
	"icon": "search",
	"description": "A product browser with filtering, search, pagination, and category tree",
	"keywords": ["browser", "products", "filter", "search", "englemond"],
	"textdomain": "englemond-products",
	"editorScript": "file:./build/editor.js",
	"viewScript": "file:./build/view.js",
	"style": ["file:./build/view.css"],
	"render": "file:./render.php",
	"attributes": {
		"productsPerPage": {
			"type": "number",
			"default": 12
		},
		"showCategoryTree": {
			"type": "boolean",
			"default": true
		},
		"showSearch": {
			"type": "boolean",
			"default": true
		},
		"noresultText": {
			"type": "string",
			"default": "No products found."
		}
	},
	"supports": {
		"html": false,
		"align": true
	}
}
