{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "englemond/gallery",
	"title": "Englemond Gallery",
	"category": "media",
	"icon": "format-gallery",
	"description": "A gallery block for Englemond products",
	"keywords": ["gallery", "images", "englemond"],
	"textdomain": "englemond-products",
	"editorScript": "file:./build/editor.js",
	"editorStyle": ["dashicons"],
	"viewScript": "file:./build/view.js",
	"style": ["file:./build/view.css"],
	"render": "file:./render.php",
	"attributes": {
		"images": {
			"type": "array",
			"default": [],
			"source": "meta",
			"meta": "gallery"
		},
		"iconSize": {
			"type": "string",
			"default": "120px"
		}
	},
	"supports": {
		"html": false,
		"align": true
	}
}
